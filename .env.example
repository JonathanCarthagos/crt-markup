# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Opcional: Para produção
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Resend (emails de convite para partilha de projetos)
RESEND_API_KEY=re_xxxxxxxxxxxx
# Opcional: domínio verificado no Resend (senão usa onboarding@resend.dev)
# RESEND_FROM_EMAIL=noreply@seudominio.com
# RESEND_FROM_NAME=CRT Markup

# URL da aplicação (para links nos emails). Na Vercel é inferido automaticamente.
# ALERTA FUTURO: Ao adicionar domínio customizado (Brevo/Resend), definir:
# NEXT_PUBLIC_APP_URL=https://seudominio.com
